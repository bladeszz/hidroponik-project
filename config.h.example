// ============================================================\n//  CONFIG.H.EXAMPLE - Configuration Template\n//  Copy this file to config.h and fill in your Supabase credentials\n// ============================================================\n\n#ifndef CONFIG_H\n#define CONFIG_H\n\n// ==================== SUPABASE SETTINGS ====================\n// Get these from your Supabase project (Settings > API)\n// 1. Go to https://supabase.com and create a project\n// 2. Copy the URL from Settings > API > Project URL\n// 3. Copy the anon key from Settings > API > Project API keys\nconst char* SUPABASE_URL = \"https://YOUR_PROJECT_ID.supabase.co\";\nconst char* SUPABASE_KEY = \"YOUR_SUPABASE_ANON_KEY_HERE\";\n\n// ==================== AUTH HEADER ====================\n// This is populated in setup() - do not modify\nchar SUPABASE_AUTH[300];\n\n// ==================== TIMING SETTINGS ====================\n#define SERIAL_PRINT_INTERVAL 2000     // Serial monitor output (ms)\n#define SUPABASE_SEND_INTERVAL 10000   // Data send interval (ms)\n#define COMMAND_CHECK_INTERVAL 5000    // Schedule fetch interval (ms)\n#define TDS_SAMPLE_INTERVAL 40         // TDS sampling (ms)\n#define AP_TIMEOUT 300                 // WiFi portal timeout (seconds) = 5 minutes\n#define WIFI_RECONNECT_INTERVAL 30000  // WiFi reconnection check (ms)\n#define WDT_TIMEOUT 60                 // Watchdog timeout (seconds)\n#define HTTP_TIMEOUT 10000             // Supabase HTTP timeout (ms)\n#define MAX_RECONNECT_ATTEMPTS 3       // WiFi reconnect attempts\n#define SCHEDULE_CHECK_INTERVAL 60000  // Scheduling engine interval (ms)\n#define PUMP_SLOT_DURATION 5           // Pump runtime per slot (minutes)\n\n// ==================== PIN DEFINITIONS ====================\n#define RESET_BTN_PIN 0     // WiFi reset button (BOOT)\n\n// TDS Sensor\n#define TDS_SIGNAL_PIN 32\n#define TDS_POWER_PIN 16\n\n// DHT22 Temperature/Humidity\n#define DHT_PIN 4\n#define DHT_TYPE DHT22\n\n// Water Level Sensor (HW-038)\n#define WATER_POWER_PIN 17\n#define WATER_SIGNAL_PIN 36\n\n// RTC Module (DS1302)\n#define RTC_DAT_PIN 26\n#define RTC_CLK_PIN 25\n#define RTC_RST_PIN 27\n\n// Relay Pins\n#define RELAY_PUMP_PIN 5    // Pump relay\n#define RELAY_LED_PIN 18    // LED relay\n\n// ==================== CONSTANTS ====================\n#define VREF 3.3\n#define TDS_SAMPLE_COUNT 30\n\n// TDS Calibration Constants (Probe: TDS Meter V1.0)\n#define TDS_FACTOR 0.5\n#define TDS_COEFF_A 133.42\n#define TDS_COEFF_B 255.86\n#define TDS_COEFF_C 857.39\n\n#endif\n